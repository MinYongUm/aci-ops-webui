# ============================================================
# .env.example
# 목적: Docker 컨테이너 환경변수 템플릿
# 용도: 로컬 개발 환경 (docker compose 연동)
#
# 사용 방법:
#   1. 이 파일을 .env 로 복사
#      cp .env.example .env   (Linux/Mac)
#      copy .env.example .env (Windows)
#   2. 실제 값으로 수정
#   3. docker compose up 실행
#
# [주의사항]
#   - .env 파일은 .gitignore 등록 대상 — 절대 커밋하지 않음
#   - 이 파일(.env.example)만 레포에 포함
# ============================================================

# ============================================================
# 앱 실행 환경
# development: 로컬 개발 환경 (디버그 로그 활성화)
# production:  운영 환경
# ============================================================
APP_ENV=development

# ============================================================
# 로그 레벨
# debug:   모든 로그 출력 (개발 환경 권장)
# info:    일반 정보 로그
# warning: 경고 이상만 출력
# ============================================================
LOG_LEVEL=debug

# ============================================================
# uvicorn 포트
# docker_compose.yml 포트 매핑과 일치해야 함 (기본값: 8000)
# ============================================================
UVICORN_PORT=8000
