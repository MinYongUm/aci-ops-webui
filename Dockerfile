# ============================================================
# Dockerfile
# 목적: aci-ops-webui FastAPI 앱 컨테이너 이미지 정의
# 용도: 로컬 개발 환경 (docker-compose 연동)
#
# 빌드 방법:
#   docker build -t aci-ops-webui .
#
# 실행 방법 (단독):
#   docker run -p 8000:8000 \
#     -v $(pwd)/backend/config.yaml:/app/backend/config.yaml \
#     aci-ops-webui
#
# [구조 주의사항]
#   - WORKDIR을 /app/backend 로 설정
#     → uvicorn main:app 실행 위치가 backend/ 이기 때문
#   - config.yaml 은 이미지에 포함하지 않음
#     → APIC 접속 정보 보안을 위해 볼륨 마운트로 주입
#   - requirements.txt 만 설치 (dev 도구 제외)
#     → Docker 이미지 경량화
# ============================================================

# ============================================================
# Base Image
# python:3.12-slim — 경량 Python 이미지 (불필요한 패키지 제외)
# ============================================================
FROM python:3.12-slim

# ============================================================
# 작업 디렉토리 설정
# /app: 프로젝트 루트
# ============================================================
WORKDIR /app

# ============================================================
# 의존성 설치
# requirements.txt 만 복사 후 설치 (런타임 패키지만)
# → 코드 변경 시 의존성 레이어 캐시 재사용 가능
# ============================================================
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# ============================================================
# 소스 코드 복사
# backend/, frontend/ 만 복사 (불필요한 파일 제외)
# ============================================================
COPY backend/ ./backend/
COPY frontend/ ./frontend/

# ============================================================
# 작업 디렉토리를 backend/ 로 변경
# uvicorn main:app 실행 위치 기준
# ============================================================
WORKDIR /app/backend

# ============================================================
# 포트 노출
# 컨테이너 내부 포트 8000 (uvicorn 기본 포트)
# ============================================================
EXPOSE 8000

# ============================================================
# 앱 실행
# --host 0.0.0.0: 컨테이너 외부에서 접근 가능하도록 설정
# --port 8000: uvicorn 포트
# ============================================================
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]