# config.yaml
# 실제 사용 시 이 파일을 config.yaml로 복사 후 수정하세요
# 이 파일은 레포에 포함됩니다 — 실제 접속 정보를 입력하지 마세요
#
# APIC 단독(1대) 구성:
#   hosts에 1개만 입력
#
# APIC 클러스터(3대) 구성:
#   hosts에 3개 모두 입력 (Primary -> Failover 순)
#   Primary 연결 실패 시 다음 host로 자동 전환됩니다

# ============================================
# APIC 접속 정보
# ============================================
apic:
  hosts:
    - "https://APIC1_IP_OR_HOSTNAME"   # Primary
    - "https://APIC2_IP_OR_HOSTNAME"   # Failover (클러스터 구성 시)
    - "https://APIC3_IP_OR_HOSTNAME"   # Failover (클러스터 구성 시)
  username: "계정명"
  password: "비밀번호"
  timeout: 30   # API 요청 타임아웃 (초) — APIC 무응답 시 hang 방지
  retry: 3      # Failover 재시도 횟수 — hosts 리스트 순서대로 시도

# ============================================
# Config Linter 설정
# ============================================
linter:
  naming:
    # enabled: true로 설정 시 NM-001, NM-002 규칙 활성화
    # false로 설정 시 Naming 규칙 전체 스킵
    enabled: true

    # 아래 prefix 항목은 선택 사항입니다
    # 값을 비워두거나 항목을 삭제하면 해당 클래스의 prefix 검사를 스킵합니다
    # 예시: tenant_prefix: "TN-"  →  TN-으로 시작하지 않는 Tenant 이름을 위반으로 탐지

    tenant_prefix: ""       # 예: "TN-"
    bd_prefix: ""           # 예: "BD-"
    epg_prefix: ""          # 예: "EPG-"
    contract_prefix: ""     # 예: "CON-"
    ap_prefix: ""           # 예: "AP-"
